<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IT Asset Management System</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-server"></i> IT Asset Manager</h1>
            <nav>
                <button class="nav-btn active" data-view="dashboard">Dashboard</button>
                <button class="nav-btn" data-view="assets">Assets</button>
                <button class="nav-btn" data-view="tickets">Tickets</button>
            </nav>
        </header>

        <!-- Dashboard View -->
        <section id="dashboard-view" class="view active">
            <div class="stats-grid">
                <div class="stat-card">
                    <i class="fas fa-laptop"></i>
                    <div class="stat-info">
                        <h3 id="total-assets">0</h3>
                        <p>Total Assets</p>
                    </div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-check-circle"></i>
                    <div class="stat-info">
                        <h3 id="active-assets">0</h3>
                        <p>Active Assets</p>
                    </div>
                </div>
                <div class="stat-card warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div class="stat-info">
                        <h3 id="maintenance-due">0</h3>
                        <p>Maintenance Due</p>
                    </div>
                </div>
                <div class="stat-card danger">
                    <i class="fas fa-ticket-alt"></i>
                    <div class="stat-info">
                        <h3 id="open-tickets">0</h3>
                        <p>Open Tickets</p>
                    </div>
                </div>
            </div>
            
            <div class="recent-activity">
                <h2>Recent Activity</h2>
                <div id="activity-list"></div>
            </div>
        </section>

        <!-- Assets View -->
        <section id="assets-view" class="view">
            <div class="section-header">
                <h2>Asset Inventory</h2>
                <button class="btn-primary" onclick="openAssetModal()">
                    <i class="fas fa-plus"></i> Add Asset
                </button>
            </div>
            
            <div class="filters">
                <input type="text" id="asset-search" placeholder="Search assets...">
                <select id="status-filter">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Retired">Retired</option>
                </select>
            </div>
            
            <table class="data-table" id="assets-table">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Device Type</th>
                        <th>Brand/Model</th>
                        <th>Location</th>
                        <th>Assigned To</th>
                        <th>Status</th>
                        <th>IP Address</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="assets-tbody"></tbody>
            </table>
        </section>

        <!-- Tickets View -->
        <section id="tickets-view" class="view">
            <div class="section-header">
                <h2>Support Tickets</h2>
                <button class="btn-primary" onclick="openTicketModal()">
                    <i class="fas fa-plus"></i> New Ticket
                </button>
            </div>
            
            <table class="data-table" id="tickets-table">
                <thead>
                    <tr>
                        <th>Ticket #</th>
                        <th>Asset</th>
                        <th>Issue Type</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tickets-tbody"></tbody>
            </table>
        </section>
    </div>

    <!-- Asset Modal -->
    <div id="asset-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2>Add New Asset</h2>
            <form id="asset-form">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Asset Tag *</label>
                        <input type="text" name="asset_tag" required>
                    </div>
                    <div class="form-group">
                        <label>Device Type *</label>
                        <select name="device_type" required>
                            <option value="Laptop">Laptop</option>
                            <option value="Desktop">Desktop</option>
                            <option value="Server">Server</option>
                            <option value="Network Equipment">Network Equipment</option>
                            <option value="Printer">Printer</option>
                            <option value="Digital Signage">Digital Signage</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Brand</label>
                        <input type="text" name="brand">
                    </div>
                    <div class="form-group">
                        <label>Model</label>
                        <input type="text" name="model">
                    </div>
                    <div class="form-group">
                        <label>Serial Number</label>
                        <input type="text" name="serial_number">
                    </div>
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="location">
                    </div>
                    <div class="form-group">
                        <label>Assigned To</label>
                        <input type="text" name="assigned_to">
                    </div>
                    <div class="form-group">
                        <label>IP Address</label>
                        <input type="text" name="ip_address" placeholder="192.168.1.1">
                    </div>
                    <div class="form-group">
                        <label>Purchase Date</label>
                        <input type="date" name="purchase_date">
                    </div>
                    <div class="form-group">
                        <label>Warranty Expiry</label>
                        <input type="date" name="warranty_expiry">
                    </div>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="3"></textarea>
                </div>
                <button type="submit" class="btn-primary">Save Asset</button>
            </form>
        </div>
    </div>

    <script src="js/app.js"></script>
</body>
</html>
